# Copy this file to .env and fill in your values.

# ── Backend connection ────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:5000
VITE_API_BASE_URL=/api
VITE_DEV_PORT=5173

# ── External CDN assets ───────────────────────────────────────────────────────
VITE_GEO_JSON_URL=https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json

# ── Google external links ─────────────────────────────────────────────────────
VITE_GOOGLE_SEARCH_CONSOLE_URL=https://search.google.com/search-console
VITE_GOOGLE_CLOUD_CONSOLE_URL=https://console.cloud.google.com/apis/library
VITE_GOOGLE_SC_API_ENABLE_URL=https://console.cloud.google.com/apis/library/searchconsole.googleapis.com

# ── Google OAuth scopes ───────────────────────────────────────────────────────
VITE_GA4_SCOPE=https://www.googleapis.com/auth/analytics.readonly
VITE_GSC_SCOPE=https://www.googleapis.com/auth/webmasters.readonly